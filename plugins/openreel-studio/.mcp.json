{
  "mcpServers": {
    "openreel-studio": {
      "command": "node",
      "args": [
        "./scripts/openreel-mcp.mjs",
        "--stdio"
      ],
      "cwd": ".",
      "env_vars": [
        "OPENREEL_BASE_URL",
        "OPENREEL_USERNAME",
        "OPENREEL_PASSWORD",
        "OPENREEL_TOKEN",
        "OPENREEL_DISCOVERY_PORTS",
        "OPENREEL_REQUEST_TIMEOUT_MS",
        "OPENREEL_CONFIG_PATH",
        "OPENREEL_REMEMBER_CONNECTION"
      ],
      "tool_timeout_sec": 1200
    }
  }
}
